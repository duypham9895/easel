{
  "compilerOptions": {
    "target": "ES2020",
    "module": "CommonJS",
    "lib": ["ES2020", "DOM"],
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "outDir": ".vercel/output",
    "rootDir": "."
  },
  "include": ["api/**/*", "lib/**/*"],
  "exclude": ["node_modules"]
}
