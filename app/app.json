{
  "expo": {
    "name": "Easel",
    "slug": "easel",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "light",
    "splash": {
      "backgroundColor": "#FBFBFD"
    },
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.easel.app"
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#FBFBFD"
      },
      "package": "com.easel.app"
    },
    "plugins": ["expo-router", "expo-notifications", "expo-image-picker", ["react-native-health", {"NSHealthShareUsageDescription": "Easel reads your menstrual cycle history to make period predictions more accurate.", "NSHealthUpdateUsageDescription": "Easel does not write to Apple Health."}]],
    "scheme": "easel",
    "extra": {
      "router": {
        "origin": false
      },
      "eas": {
        "projectId": "7dc0f149-563f-4ea5-94d3-a4fe10830b4b"
      }
    },
    "owner": "duypham9895"
  }
}
