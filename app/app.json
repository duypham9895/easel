{
  "expo": {
    "name": "Easel",
    "slug": "easel",
    "version": "1.5.1",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "light",
    "splash": {
      "backgroundColor": "#FBFBFD"
    },
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.easel.app",
      "buildNumber": "1",
      "infoPlist": {
        "ITSAppUsesNonExemptEncryption": false
      }
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#FBFBFD"
      },
      "package": "com.easel.app",
      "versionCode": 1
    },
    "plugins": [
      "expo-router",
      "expo-notifications",
      "expo-image-picker",
      [
        "react-native-health",
        {
          "NSHealthShareUsageDescription": "Easel reads your menstrual cycle history to make period predictions more accurate.",
          "NSHealthUpdateUsageDescription": "Easel does not write to Apple Health."
        }
      ],
      "@react-native-community/datetimepicker",
      "expo-localization"
    ],
    "scheme": "easel",
    "extra": {
      "router": {
        "origin": false
      },
      "eas": {
        "projectId": "7dc0f149-563f-4ea5-94d3-a4fe10830b4b"
      }
    },
    "owner": "duypham9895"
  }
}
