# ── Expo / EAS ────────────────────────────────────────────────────────────────
# Get from: Expo Dashboard → Project → Project ID
# Required for Expo push tokens (modern format)
EXPO_PUBLIC_EAS_PROJECT_ID=

# ── Supabase ──────────────────────────────────────────────────────────────────
# Get these from: Supabase Dashboard → Settings → API
EXPO_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
EXPO_PUBLIC_SUPABASE_ANON_KEY=

# ── Vercel proxy (MiniMax AI greetings) ────────────────────────────────────────
# URL of your deployed Vercel proxy (no trailing slash)
# Leave empty to use static fallback greetings only
EXPO_PUBLIC_PROXY_URL=https://your-proxy.vercel.app

# Must match CLIENT_TOKEN in the Vercel environment variables
EXPO_PUBLIC_CLIENT_TOKEN=

EXPO_PRIVATE_SUPERBASE_DATABASE_PASSWORD=aZ4^B5P#^Ce!SFdv8s6W